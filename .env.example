# Jami Harness environment (example)
#
# Copy to `.env` (gitignored) and fill in values. Only `.env.example` is tracked,
# and it must never contain real secrets — placeholders only.
#
# Product telemetry is OSS-safe and OFF by default. It only initializes when ALL of:
#   - JAMI_TELEMETRY is truthy (1/true/yes/on), AND
#   - DO_NOT_TRACK is unset (or 0/false), AND
#   - the process is not running in CI, AND
#   - a PostHog project key is present.
# When telemetry is enabled, the harness emits RUN METADATA ONLY (latency, token
# estimates, cost, error/exception signals, feature-flag checks) to PostHog — never
# prompt/response content, and never PII. See docs/operations/telemetry.md.

# PostHog project key (publishable phc_* key; client-exposed, safe to ship in a build).
POSTHOG_KEY=

# PostHog host. US cloud: https://us.posthog.com  EU cloud: https://eu.posthog.com
POSTHOG_HOST=

# Opt-in switch for product telemetry. Leave empty/unset to keep telemetry OFF.
# Set to 1 to enable (subject to the DO_NOT_TRACK / CI / key gates above).
JAMI_TELEMETRY=

# Optional: a stable, non-identifying distinct id for telemetry events.
# Defaults to an anonymous token when unset. Never set this to PII.
JAMI_TELEMETRY_DISTINCT_ID=

# Optional escape hatch to allow telemetry in CI (off unless explicitly set).
# JAMI_TELEMETRY_ALLOW_CI=

# Standard opt-out signal (https://consoledonottrack.com). Any non-"0" value disables
# all telemetry regardless of JAMI_TELEMETRY.
# DO_NOT_TRACK=
