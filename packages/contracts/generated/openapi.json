{
  "components": {
    "schemas": {
      "ActionRef": {
        "$id": "https://jami.studio/schemas/harness/action-ref.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "actionId": {
            "pattern": "^act_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "confirmationMode": {
            "enum": [
              "none",
              "confirm",
              "approval_required",
              "owner_required"
            ],
            "type": "string"
          },
          "denial": {
            "additionalProperties": false,
            "properties": {
              "auditRef": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            },
            "required": [
              "reason",
              "auditRef"
            ],
            "type": "object"
          },
          "evidenceRef": {
            "type": "string"
          },
          "inputSchemaRef": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "policyScope": {
            "type": "string"
          },
          "risk": {
            "enum": [
              "read",
              "write",
              "destructive",
              "external",
              "secret_adjacent"
            ],
            "type": "string"
          },
          "route": {
            "pattern": "^harness://actions/[a-z0-9][a-z0-9-]*$",
            "type": "string"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          },
          "state": {
            "enum": [
              "available",
              "disabled",
              "denied",
              "pending_approval",
              "executed",
              "failed"
            ],
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "actionId",
          "label",
          "route",
          "risk",
          "policyScope",
          "confirmationMode",
          "state"
        ],
        "title": "actionRef",
        "type": "object"
      },
      "ArtifactView": {
        "$id": "https://jami.studio/schemas/harness/artifact-view.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "artifactId": {
            "pattern": "^art_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "artifactViewId": {
            "pattern": "^artv_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "kind": {
            "enum": [
              "report",
              "patch",
              "document",
              "image",
              "trace",
              "evidence",
              "release_packet"
            ],
            "type": "string"
          },
          "promotionState": {
            "enum": [
              "draft",
              "reviewed",
              "accepted",
              "rejected",
              "promoted"
            ],
            "type": "string"
          },
          "provenance": {
            "additionalProperties": false,
            "properties": {
              "evidenceRef": {
                "type": "string"
              },
              "runId": {
                "pattern": "^run_[a-z0-9][a-z0-9_-]*$",
                "type": "string"
              },
              "sourceCommit": {
                "type": "string"
              }
            },
            "required": [
              "runId",
              "sourceCommit",
              "evidenceRef"
            ],
            "type": "object"
          },
          "renderers": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "componentRef": {
                  "type": "string"
                },
                "mode": {
                  "enum": [
                    "text",
                    "markdown",
                    "diff",
                    "image",
                    "json",
                    "studio_ui"
                  ],
                  "type": "string"
                },
                "rendererId": {
                  "type": "string"
                },
                "unsupportedReason": {
                  "type": "string"
                }
              },
              "required": [
                "rendererId",
                "mode"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "artifactViewId",
          "artifactId",
          "kind",
          "promotionState",
          "renderers",
          "provenance"
        ],
        "title": "artifactView",
        "type": "object"
      },
      "CapabilityManifest": {
        "$id": "https://jami.studio/schemas/harness/capability-manifest.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "capabilityClass": {
            "enum": [
              "core_invariant",
              "included_default",
              "replaceable_module",
              "optional_surface",
              "adapter"
            ],
            "type": "string"
          },
          "capabilityId": {
            "pattern": "^cap_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "failureModes": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "type": "string"
                },
                "observableAs": {
                  "enum": [
                    "typed_result",
                    "audit_event",
                    "trace_event",
                    "evidence_packet"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "mode",
                "observableAs"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "features": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "featureId": {
                  "type": "string"
                },
                "notes": {
                  "type": "string"
                },
                "support": {
                  "enum": [
                    "supported",
                    "unsupported",
                    "denied_by_policy",
                    "requires_adapter",
                    "requires_approval"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "featureId",
                "support"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "ownerPackage": {
            "pattern": "^@jami-studio/harness[a-z0-9-]*$",
            "type": "string"
          },
          "replacementCompatibility": {
            "additionalProperties": false,
            "properties": {
              "contractVersion": {
                "type": "string"
              },
              "mustPreserve": {
                "items": {
                  "enum": [
                    "policy",
                    "audit",
                    "artifact",
                    "evidence",
                    "checkpoint",
                    "redaction"
                  ],
                  "type": "string"
                },
                "type": "array"
              },
              "portId": {
                "type": "string"
              }
            },
            "required": [
              "portId",
              "contractVersion",
              "mustPreserve"
            ],
            "type": "object"
          },
          "requiredScopes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          }
        },
        "required": [
          "schemaVersion",
          "capabilityId",
          "ownerPackage",
          "capabilityClass",
          "features",
          "requiredScopes",
          "failureModes",
          "replacementCompatibility"
        ],
        "title": "capabilityManifest",
        "type": "object"
      },
      "EvidencePacket": {
        "$id": "https://jami.studio/schemas/harness/evidence-packet.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "acceptedContracts": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "artifacts": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "artifactId": {
                  "pattern": "^art_[a-z0-9][a-z0-9_-]*$",
                  "type": "string"
                },
                "kind": {
                  "enum": [
                    "schema",
                    "fixture",
                    "generated_reference",
                    "report",
                    "log"
                  ],
                  "type": "string"
                },
                "path": {
                  "type": "string"
                }
              },
              "required": [
                "artifactId",
                "path",
                "kind"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "commands": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "command": {
                  "type": "string"
                },
                "evidenceRef": {
                  "type": "string"
                },
                "recordedAt": {
                  "format": "date-time",
                  "type": "string"
                },
                "status": {
                  "enum": [
                    "passed",
                    "failed",
                    "unavailable",
                    "not_run"
                  ],
                  "type": "string"
                },
                "unavailableReason": {
                  "type": "string"
                }
              },
              "required": [
                "command",
                "status",
                "recordedAt"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "evidenceId": {
            "pattern": "^ev_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "freshnessClass": {
            "enum": [
              "current_run",
              "same_day",
              "source_locked",
              "stale"
            ],
            "type": "string"
          },
          "redaction": {
            "additionalProperties": false,
            "properties": {
              "containsSecrets": {
                "type": "boolean"
              },
              "notes": {
                "type": "string"
              },
              "privatePayloadPolicy": {
                "enum": [
                  "none",
                  "redacted",
                  "omitted"
                ],
                "type": "string"
              }
            },
            "required": [
              "containsSecrets",
              "privatePayloadPolicy"
            ],
            "type": "object"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          },
          "source": {
            "additionalProperties": false,
            "properties": {
              "commit": {
                "type": "string"
              },
              "recordedAt": {
                "format": "date-time",
                "type": "string"
              },
              "repo": {
                "type": "string"
              }
            },
            "required": [
              "repo",
              "commit",
              "recordedAt"
            ],
            "type": "object"
          },
          "subject": {
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "evidenceId",
          "subject",
          "freshnessClass",
          "source",
          "commands",
          "artifacts",
          "redaction",
          "acceptedContracts"
        ],
        "title": "evidencePacket",
        "type": "object"
      },
      "PrimitiveManifest": {
        "$id": "https://jami.studio/schemas/harness/primitive-manifest.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "adapterCompatibility": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "auditEventShape": {
            "type": "string"
          },
          "docs": {
            "additionalProperties": false,
            "properties": {
              "referencePath": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              }
            },
            "required": [
              "summary",
              "referencePath"
            ],
            "type": "object"
          },
          "inputSchemaRef": {
            "type": "string"
          },
          "outputSchemaRef": {
            "type": "string"
          },
          "ownerPackage": {
            "pattern": "^@jami-studio/harness[a-z0-9-]*$",
            "type": "string"
          },
          "policyRequirements": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "primitiveClass": {
            "enum": [
              "run",
              "tool",
              "policy",
              "artifact",
              "memory",
              "context",
              "evidence",
              "ui_reference",
              "docs"
            ],
            "type": "string"
          },
          "primitiveId": {
            "pattern": "^prim_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          },
          "traceSpanShape": {
            "type": "string"
          },
          "verification": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "primitiveId",
          "version",
          "ownerPackage",
          "primitiveClass",
          "inputSchemaRef",
          "outputSchemaRef",
          "policyRequirements",
          "auditEventShape",
          "traceSpanShape",
          "docs",
          "verification"
        ],
        "title": "primitiveManifest",
        "type": "object"
      },
      "RunEvent": {
        "$id": "https://jami.studio/schemas/harness/run-event.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "actionRef": {
            "type": "string"
          },
          "artifactViewRef": {
            "type": "string"
          },
          "eventId": {
            "pattern": "^evt_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "eventType": {
            "enum": [
              "run.started",
              "run.progress",
              "run.completed",
              "run.failed",
              "policy.decision",
              "approval.requested",
              "tool.call.requested",
              "tool.call.completed",
              "artifact.created",
              "ui.payload.emitted",
              "renderer.error"
            ],
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "occurredAt": {
            "format": "date-time",
            "type": "string"
          },
          "policyDecision": {
            "additionalProperties": false,
            "properties": {
              "auditRef": {
                "type": "string"
              },
              "decision": {
                "enum": [
                  "allow",
                  "deny",
                  "needs_approval",
                  "needs_owner"
                ],
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "scope": {
                "type": "string"
              }
            },
            "required": [
              "decision",
              "scope"
            ],
            "type": "object"
          },
          "rendererState": {
            "enum": [
              "not_requested",
              "rendered",
              "unsupported_component",
              "invalid_payload",
              "error_state"
            ],
            "type": "string"
          },
          "runId": {
            "pattern": "^run_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          },
          "sequence": {
            "minimum": 0,
            "type": "integer"
          },
          "taskId": {
            "pattern": "^task_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "traceRef": {
            "additionalProperties": false,
            "properties": {
              "spanId": {
                "type": "string"
              },
              "traceId": {
                "type": "string"
              }
            },
            "required": [
              "traceId"
            ],
            "type": "object"
          },
          "uiPayloadRef": {
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "eventId",
          "runId",
          "sequence",
          "occurredAt",
          "eventType"
        ],
        "title": "runEvent",
        "type": "object"
      },
      "SuiteRef": {
        "$id": "https://jami.studio/schemas/harness/suite-ref.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "appShellId": {
            "type": "string"
          },
          "installedItems": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "lane": {
            "enum": [
              "workspace",
              "docs",
              "ops",
              "governance",
              "custom"
            ],
            "type": "string"
          },
          "optionalHarnessCapabilities": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "routeMap": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "path": {
                  "type": "string"
                },
                "routeId": {
                  "type": "string"
                }
              },
              "required": [
                "routeId",
                "path"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          },
          "suiteId": {
            "pattern": "^suite_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "suiteId",
          "lane",
          "installedItems",
          "routeMap",
          "optionalHarnessCapabilities"
        ],
        "title": "suiteRef",
        "type": "object"
      },
      "ThemeRef": {
        "$id": "https://jami.studio/schemas/harness/theme-ref.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "restoreTarget": {
            "additionalProperties": false,
            "properties": {
              "itemPath": {
                "type": "string"
              },
              "packageName": {
                "const": "@jami-studio/ui",
                "type": "string"
              }
            },
            "required": [
              "packageName",
              "itemPath"
            ],
            "type": "object"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          },
          "source": {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "factory",
                  "custom"
                ],
                "type": "string"
              },
              "owner": {
                "const": "studio-ui",
                "type": "string"
              },
              "registryItemId": {
                "type": "string"
              }
            },
            "required": [
              "owner",
              "registryItemId",
              "kind"
            ],
            "type": "object"
          },
          "themeId": {
            "pattern": "^theme_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "tokenSchemaVersion": {
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "themeId",
          "tokenSchemaVersion",
          "source",
          "restoreTarget"
        ],
        "title": "themeRef",
        "type": "object"
      },
      "ThreatModelFixtureCatalog": {
        "$id": "https://jami.studio/schemas/harness/threat-model-fixture-catalog.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "catalogId": {
            "pattern": "^tmc_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "fixtures": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "caseId": {
                  "type": "string"
                },
                "expectedOutcome": {
                  "enum": [
                    "allow",
                    "deny",
                    "redact",
                    "error_state",
                    "unsupported"
                  ],
                  "type": "string"
                },
                "expectedValid": {
                  "type": "boolean"
                },
                "fixturePath": {
                  "type": "string"
                },
                "riskId": {
                  "pattern": "^risk_[a-z0-9][a-z0-9_-]*$",
                  "type": "string"
                }
              },
              "required": [
                "caseId",
                "riskId",
                "expectedValid",
                "expectedOutcome"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "risks": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "category": {
                  "enum": [
                    "prompt_injection",
                    "tool_metadata_poisoning",
                    "transport_abuse",
                    "secret_exfiltration",
                    "approval_replay",
                    "denied_action",
                    "redaction_failure",
                    "memory_leakage"
                  ],
                  "type": "string"
                },
                "expectedControl": {
                  "type": "string"
                },
                "riskId": {
                  "pattern": "^risk_[a-z0-9][a-z0-9_-]*$",
                  "type": "string"
                }
              },
              "required": [
                "riskId",
                "category",
                "expectedControl"
              ],
              "type": "object"
            },
            "minItems": 1,
            "type": "array"
          },
          "schemaVersion": {
            "const": "2026-06-09"
          },
          "surface": {
            "enum": [
              "policy",
              "tool",
              "ui_action",
              "memory",
              "evidence",
              "cross_surface"
            ],
            "type": "string"
          }
        },
        "required": [
          "schemaVersion",
          "catalogId",
          "surface",
          "risks",
          "fixtures"
        ],
        "title": "threatModelFixtureCatalog",
        "type": "object"
      },
      "UiPayload": {
        "$id": "https://jami.studio/schemas/harness/ui-payload.schema.json",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "actionRefs": {
            "items": {
              "pattern": "^act_[a-z0-9][a-z0-9_-]*$",
              "type": "string"
            },
            "type": "array"
          },
          "artifactViewRefs": {
            "items": {
              "pattern": "^artv_[a-z0-9][a-z0-9_-]*$",
              "type": "string"
            },
            "type": "array"
          },
          "children": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "componentRef": {
            "additionalProperties": false,
            "properties": {
              "allowlisted": {
                "type": "boolean"
              },
              "name": {
                "pattern": "^[a-z][a-z0-9-]*$",
                "type": "string"
              },
              "namespace": {
                "const": "@jami-studio/ui",
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            },
            "required": [
              "namespace",
              "name",
              "version"
            ],
            "type": "object"
          },
          "fallback": {
            "additionalProperties": false,
            "properties": {
              "message": {
                "type": "string"
              },
              "mode": {
                "enum": [
                  "text",
                  "artifact_link",
                  "unsupported_component",
                  "invalid_payload",
                  "renderer_error"
                ],
                "type": "string"
              }
            },
            "required": [
              "mode",
              "message"
            ],
            "type": "object"
          },
          "payloadId": {
            "pattern": "^uip_[a-z0-9][a-z0-9_-]*$",
            "type": "string"
          },
          "props": {
            "type": "object"
          },
          "provenance": {
            "additionalProperties": false,
            "properties": {
              "emittedBy": {
                "enum": [
                  "harness",
                  "adapter"
                ],
                "type": "string"
              },
              "evidenceRef": {
                "type": "string"
              },
              "runId": {
                "pattern": "^run_[a-z0-9][a-z0-9_-]*$",
