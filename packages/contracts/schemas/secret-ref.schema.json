{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jami.studio/schemas/harness/secret-ref.schema.json",
  "title": "secretRef",
  "type": "object",
  "required": [
    "schemaVersion",
    "secretId",
    "provider",
    "scope",
    "redactionClass",
    "createdAt"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "2026-06-09" },
    "secretId": { "type": "string", "pattern": "^sec_[a-z0-9][a-z0-9_-]*$" },
    "provider": { "type": "string", "enum": ["env", "vault", "hosted_secret_store", "user_adapter"] },
    "scope": { "type": "string" },
    "redactionClass": { "type": "string", "enum": ["credential", "token", "private_key", "connection_string", "private_payload"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "rotationRef": { "type": "string" },
    "description": { "type": "string" }
  }
}
