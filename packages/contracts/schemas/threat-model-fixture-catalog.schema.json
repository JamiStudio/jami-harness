{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jami.studio/schemas/harness/threat-model-fixture-catalog.schema.json",
  "title": "threatModelFixtureCatalog",
  "type": "object",
  "required": ["schemaVersion", "catalogId", "surface", "risks", "fixtures"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "2026-06-09" },
    "catalogId": { "type": "string", "pattern": "^tmc_[a-z0-9][a-z0-9_-]*$" },
    "surface": { "type": "string", "enum": ["policy", "tool", "ui_action", "memory", "evidence", "cross_surface"] },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["riskId", "category", "expectedControl"],
        "additionalProperties": false,
        "properties": {
          "riskId": { "type": "string", "pattern": "^risk_[a-z0-9][a-z0-9_-]*$" },
          "category": {
            "type": "string",
            "enum": [
              "prompt_injection",
              "tool_metadata_poisoning",
              "transport_abuse",
              "secret_exfiltration",
              "approval_replay",
              "scope_escalation",
              "denied_action",
              "redaction_failure",
              "memory_leakage"
            ]
          },
          "expectedControl": { "type": "string" }
        }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["caseId", "riskId", "expectedValid", "expectedOutcome"],
        "additionalProperties": false,
        "properties": {
          "caseId": { "type": "string" },
          "riskId": { "type": "string", "pattern": "^risk_[a-z0-9][a-z0-9_-]*$" },
          "expectedValid": { "type": "boolean" },
          "expectedOutcome": { "type": "string", "enum": ["allow", "deny", "redact", "error_state", "unsupported"] },
          "fixturePath": { "type": "string" }
        }
      }
    }
  }
}
