{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jami.studio/schemas/harness/approval-request.schema.json",
  "title": "approvalRequest",
  "type": "object",
  "required": [
    "schemaVersion",
    "approvalId",
    "runId",
    "actorId",
    "projectId",
    "environment",
    "actionId",
    "requestedScopes",
    "risk",
    "status",
    "requestedAt",
    "expiresAt",
    "auditRef"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "2026-06-09" },
    "approvalId": { "type": "string", "pattern": "^apr_[a-z0-9][a-z0-9_-]*$" },
    "runId": { "type": "string", "pattern": "^run_[a-z0-9][a-z0-9_-]*$" },
    "actorId": { "type": "string", "pattern": "^actor_[a-z0-9][a-z0-9_-]*$" },
    "projectId": { "type": "string", "pattern": "^proj_[a-z0-9][a-z0-9_-]*$" },
    "environment": { "type": "string", "enum": ["local", "preview", "production"] },
    "actionId": { "type": "string", "pattern": "^act_[a-z0-9][a-z0-9_-]*$" },
    "requestedScopes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "risk": { "type": "string", "enum": ["write", "destructive", "external", "secret_adjacent"] },
    "status": { "type": "string", "enum": ["requested", "approved", "denied", "expired", "replayed", "cancelled"] },
    "requestedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "resolvedAt": { "type": "string", "format": "date-time" },
    "replayRef": { "type": "string" },
    "auditRef": { "type": "string", "pattern": "^aud_[a-z0-9][a-z0-9_-]*$" },
    "evidenceRef": { "type": "string", "pattern": "^ev_[a-z0-9][a-z0-9_-]*$" }
  }
}
