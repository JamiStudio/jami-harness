{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jami.studio/schemas/harness/evidence-packet.schema.json",
  "title": "evidencePacket",
  "type": "object",
  "required": [
    "schemaVersion",
    "evidenceId",
    "subject",
    "freshnessClass",
    "source",
    "commands",
    "artifacts",
    "redaction",
    "acceptedContracts"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "2026-06-09" },
    "evidenceId": { "type": "string", "pattern": "^ev_[a-z0-9][a-z0-9_-]*$" },
    "subject": { "type": "string" },
    "freshnessClass": { "type": "string", "enum": ["current_run", "same_day", "source_locked", "stale"] },
    "source": {
      "type": "object",
      "required": ["repo", "commit", "ref", "recordedAt"],
      "additionalProperties": false,
      "properties": {
        "repo": { "type": "string" },
        "commit": { "type": "string" },
        "ref": { "type": "string" },
        "recordedAt": { "type": "string", "format": "date-time" }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "status", "recordedAt"],
        "additionalProperties": false,
        "properties": {
          "command": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "unavailable", "not_run"] },
          "recordedAt": { "type": "string", "format": "date-time" },
          "evidenceRef": { "type": "string" },
          "unavailableReason": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifactId", "path", "kind"],
        "additionalProperties": false,
        "properties": {
          "artifactId": { "type": "string", "pattern": "^art_[a-z0-9][a-z0-9_-]*$" },
          "path": { "type": "string" },
          "kind": { "type": "string", "enum": ["schema", "fixture", "generated_reference", "report", "log"] }
        }
      }
    },
    "redaction": {
      "type": "object",
      "required": ["containsSecrets", "privatePayloadPolicy"],
      "additionalProperties": false,
      "properties": {
        "containsSecrets": { "type": "boolean" },
        "privatePayloadPolicy": { "type": "string", "enum": ["none", "redacted", "omitted"] },
        "notes": { "type": "string" }
      }
    },
    "acceptedContracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "version"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    }
  }
}
