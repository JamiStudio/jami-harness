{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jami.studio/schemas/harness/workspace-ref.schema.json",
  "title": "workspaceRef",
  "type": "object",
  "required": ["schemaVersion", "workspaceId", "audience", "installedItems", "routeMap", "optionalHarnessCapabilities"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "2026-06-09" },
    "workspaceId": { "type": "string", "pattern": "^workspace_[a-z0-9][a-z0-9_-]*$" },
    "audience": { "type": "string", "enum": ["workspace", "docs", "operations", "governance", "custom"] },
    "appShellId": { "type": "string" },
    "installedItems": {
      "type": "array",
      "items": { "type": "string" }
    },
    "routeMap": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["routeId", "path"],
        "additionalProperties": false,
        "properties": {
          "routeId": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "optionalHarnessCapabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "registryState": {
      "type": "string",
      "enum": ["current", "missing_dependency", "unsupported_workspace_version", "stale_registry_item"]
    },
    "evidenceRef": { "type": "string" }
  }
}
