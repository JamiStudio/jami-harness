{
  "$schema": "../../schemas/workspace-ref.schema.json",
  "expectedValid": true,
  "caseId": "phase2-workspace-ref-states",
  "description": "Workspace ref fixture covers workspace roots, pages, blocks, primitive dependencies, harness capabilities, and stale or missing registry states.",
  "coverage": [
    "workspace_root",
    "page",
    "block",
    "primitive_dependency",
    "harness_capability",
    "missing_dependency",
    "unsupported_workspace_version",
    "stale_registry_item"
  ],
  "payload": {
    "schemaVersion": "2026-06-09",
    "workspaceId": "workspace_phase2_root",
    "audience": "operations",
    "appShellId": "ops-workspace-shell",
    "installedItems": [
      "@jami-studio/ui/workspaces/ops",
      "@jami-studio/ui/pages/run-detail",
      "@jami-studio/ui/blocks/action-panel",
      "@jami-studio/ui/primitives/status-badge"
    ],
    "routeMap": [
      {
        "routeId": "workspace-root",
        "path": "/ops"
      },
      {
        "routeId": "run-detail",
        "path": "/ops/runs/:runId"
      }
    ],
    "optionalHarnessCapabilities": ["cap_runtime", "cap_artifacts", "cap_evidence"],
    "registryState": "stale_registry_item",
    "evidenceRef": "ev_phase2_contracts"
  }
}
